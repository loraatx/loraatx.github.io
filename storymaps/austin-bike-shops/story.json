        "circle-radius": 8,
        "circle-color": "#2f855a",
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 2,
        "circle-opacity": 0
      },
      "transitionOpacity": 0.95,
      "transitionDuration": 700
    }
  ],

